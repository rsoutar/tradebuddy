TRADING_BOT_ENV=development
TRADING_BOT_SYMBOL=BTCUSDT
TRADING_BOT_LOG_LEVEL=INFO
TRADING_BOT_STATE_DIR=.data/state
TRADING_BOT_LOG_DIR=.data/logs

TRADING_BOT_EXCHANGE_ID=binance
TRADING_BOT_EXCHANGE_MARKET_TYPE=spot
TRADING_BOT_EXCHANGE_API_KEY=
TRADING_BOT_EXCHANGE_API_SECRET=
TRADING_BOT_EXCHANGE_SANDBOX=true

TRADING_BOT_MARKETDATA_WS_ENABLED=true
TRADING_BOT_MARKETDATA_WS_URL=wss://data-stream.binance.vision
TRADING_BOT_MARKETDATA_WS_TIMEOUT_SECONDS=2.0

TRADING_BOT_AI_PROVIDER=xai
TRADING_BOT_AI_ENABLED=false
TRADING_BOT_AI_API_KEY=

AUTH_SESSION_SECRET=replace-with-a-long-random-string
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# Optional. If omitted, the app uses the current origin + /auth/line
LINE_REDIRECT_URI=

VITE_API_BASE_URL=http://127.0.0.1:8000
